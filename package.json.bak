{
  "name": "hi-way-shuttle",
  "version": "1.0.0",
  "description": "Hi-Way-Shuttle — Telegram Mini App, Messenger Bot & Landing Page",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node test/smoke.js",
    "docker": "docker build -t hi-way-shuttle . && docker run -p 3000:3000 --env-file .env hi-way-shuttle"
  },
  "dependencies": {
    "express": "^4.21.0",
    "body-parser": "^1.20.3",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "axios": "^1.7.7"
  }
}
